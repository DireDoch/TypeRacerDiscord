# Variables d'environnement du frontend (Vite). Copier en `.env`.
# Seules les variables préfixées VITE_ sont exposées au bundle client.

# Client ID Discord (PUBLIC — pas un secret ; le secret reste côté backend).
# Absent → MODE DEV : pas de handshake Embedded App SDK, token de test (dev-player-1).
# Doit matcher DISCORD_CLIENT_ID côté backend pour l'OAuth réel.
VITE_DISCORD_CLIENT_ID=1525959658164981930
