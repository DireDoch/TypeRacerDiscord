# Variables d'environnement du backend TypeRacerDiscord.
# Copier en `.env` et renseigner, OU exporter dans le shell avant `cargo run`.
# (Le serveur lit l'environnement du process ; aucun secret n'est exposé au client.)

# --- Base de données -------------------------------------------------------
# Fichier SQLite (créé au démarrage si absent). Défaut si non défini : sqlite:typeracer.db
DATABASE_URL=sqlite:typeracer.db

# --- OAuth Discord (scope identify) ----------------------------------------
# Si ces DEUX variables sont absentes/vides → MODE DEV : le Bearer token sert de
# player_id (test local au curl), et POST /token renvoie 503.
# Renseignées → échange réel du code (POST /token) + résolution via /users/@me.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Proxy citations (GET /api/quote) --------------------------------------
# Clé API-Ninjas, injectée côté serveur dans l'en-tête X-Api-Key. Absente/vide →
# GET /api/quote renvoie 502 (proxy non configuré).
APININJAS_API_KEY=

# --- Fichiers statiques (origine unique) -----------------------------------
# Dossier du build Vite servi en fallback (SPA → index.html). Défaut : ../frontend/dist
STATIC_DIR=../frontend/dist
